# ============================================
# Medical Centre Platform — Environment Variables
# ============================================
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.

# --------------------------------------------
# Core Security (REQUIRED)
# --------------------------------------------
SECRET_KEY=your-super-secret-key-min-32-chars-here-change-me

# --------------------------------------------
# Database — PostgreSQL ONLY
# --------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/medical_system
# Or individual variables for setup_db.py:
PG_USER=postgres
PG_PASSWORD=your-secure-postgres-password
PG_HOST=localhost
PG_PORT=5432
PG_DB_NAME=medical_system

# Testing database (separate PostgreSQL database recommended)
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/medical_system_test

# --------------------------------------------
# Flask Environment
# --------------------------------------------
FLASK_ENV=development
FLASK_DEBUG=false
HOST=127.0.0.1
PORT=8080

# --------------------------------------------
# Session Security
# --------------------------------------------
SESSION_COOKIE_SECURE=false
REMEMBER_COOKIE_SECURE=false

# --------------------------------------------
# Default Admin User (first manual setup if needed)
# --------------------------------------------
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-this-secure-password
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
DEFAULT_ADMIN_NAME=مدير النظام

# --------------------------------------------
# Mail Server
# --------------------------------------------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=your-mail-password
MAIL_DEFAULT_SENDER=noreply@yourdomain.com

# --------------------------------------------
# Currency
# --------------------------------------------
DEFAULT_CURRENCY=ILS

# --------------------------------------------
# Deployment Mode (production SaaS stack)
# --------------------------------------------
DEPLOYMENT_MODE=saas
ENABLE_SAAS_MODE=true
CELERY_ENABLED=true
CELERY_BROKER_URL=redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

# Stripe (SaaS billing — optional until go-live)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
SAAS_REQUIRE_PAYMENT_AT_SIGNUP=false

# Platform bootstrap (set true only to skip catalog seed on app start)
# SKIP_PLATFORM_BOOTSTRAP=false

# SaaS tenant resolution
# Supported values: domain, subdomain, path, or comma-separated values such as domain,path.
TENANT_RESOLUTION_MODE=domain
TENANT_BASE_DOMAIN=

# --------------------------------------------
# WhatsApp Business API (Meta)
# --------------------------------------------
WHATSAPP_API_TOKEN=your-whatsapp-api-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# --------------------------------------------
# Printing / Devices
# --------------------------------------------
THERMAL_PRINTER_PORT=COM3
BARCODE_SCANNER_ENABLED=true
BIOMETRIC_DEVICE_ENABLED=false

# --------------------------------------------
# Cloud / Tenant (future)
# --------------------------------------------
TENANT_RESOLUTION_MODE=subdomain
PLATFORM_OWNER_API_KEY=your-platform-api-key
